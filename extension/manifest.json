{
  "manifest_version": 3,
  "name": "Universal Trust Wallet",
  "version": "1.0.0",
  "description": "Verifies academic and employment credentials of institution-published, privacy-preserving bloom filters.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.github.com/*",
    "https://leetcode.com/*",
    "https://*.github.io/*",
    "https://*/.well-known/verified-alumni.bin",
    "https://*/.well-known/current-active.bin"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.github.com/*",
        "https://leetcode.com/*"
      ],
      "js": [
        "bloom.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "Universal Trust Wallet — credential verification"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
