{
  "manifest_version": 3,
  "name": "Universal Trust Wallet",
  "version": "2.0.0",
  "description": "Zero-server, cryptographically secure identity verification extension.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.github.com/*",
    "https://*.leetcode.com/*",
    "https://*.github.io/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/in/*",
        "https://github.com/*",
        "https://leetcode.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'; require-trusted-types-for 'script';"
  }
}